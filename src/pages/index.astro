---
export const prerender = false;

import Link from "../components/Link.astro";
import SocialButton from "../components/SocialButton.astro";
import Layout from "../layouts/Layout.astro";

const DISCORD_ID = "677724144762355714";
const lanyardUrl = `https://api.lanyard.rest/v1/users/${DISCORD_ID}`;

let discordData: any = null;
try {
	const res = await fetch(lanyardUrl, {
		cache: "no-store",
	});
	if (res.ok) {
		const body = await res.json();
		if (body.success) {
			discordData = body.data;
		}
	}
} catch (e) {
	console.error("Failed to fetch lanyard data:", e);
}

const statusMap: Record<string, string> = {
	online: "online",
	idle: "idle",
	dnd: "dnd",
	offline: "offline",
};

const initialStatus = discordData
	? statusMap[discordData.discord_status] || "offline"
	: "offline";
const initialAvatar = discordData?.discord_user?.avatar
	? `https://cdn.discordapp.com/avatars/${DISCORD_ID}/${discordData.discord_user.avatar}.webp?size=128`
	: "chloe.webp";
const initialName = discordData?.discord_user
	? discordData.discord_user.display_name || discordData.discord_user.username
	: "ticua";
const initialUser = discordData?.discord_user
	? `@${discordData.discord_user.username}`
	: "@.ticua";

const activities = discordData?.activities || [];
const gameAct = activities.find((a: any) => a.type === 0);
let actSrc = "";
if (gameAct && gameAct.assets && gameAct.assets.large_image) {
	const assetId = gameAct.assets.large_image;
	actSrc = assetId.startsWith("mp:external")
		? `https://media.discordapp.net/external/${assetId.split("mp:external/")[1]}`
		: `https://cdn.discordapp.com/app-assets/${gameAct.application_id}/${assetId}.png`;
}

const spotify = discordData?.spotify;

let initialSpotifyCur = "0:00";
let initialSpotifyTot = "0:00";
let initialSpotifyPercent = 0;

if (spotify) {
	const now = Date.now();
	const total = spotify.timestamps.end - spotify.timestamps.start;
	const progress = Math.min(now - spotify.timestamps.start, total);
	initialSpotifyPercent = (progress / total) * 100;

	const formatMs = (ms: number) => {
		const seconds = Math.floor((ms / 1000) % 60);
		const minutes = Math.floor((ms / (1000 * 60)) % 60);
		return `${minutes}:${seconds.toString().padStart(2, "0")}`;
	};
	initialSpotifyCur = formatMs(progress);
	initialSpotifyTot = formatMs(total);
}
---

<Layout>
