					</div>
					<div class={`dc-top flex items-center gap-4`} id="dcTop">
						<div class="dc-avatar-wrap relative">
							<img
								alt="avatar"
								class="dc-avatar w-[4.5rem] h-[4.5rem] rounded-full border border-border-subtle"
								id="dcAvatar"
								src={initialAvatar}
							/>
							<span
								class={`dc-status absolute bottom-0.5 right-0.5 w-4 h-4 rounded-full border-2 border-[#18181d] ${initialStatus}`}
