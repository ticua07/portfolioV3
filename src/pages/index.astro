		background-size: 40px 40px;
	}
	.material-symbols-outlined {
		font-variation-settings:
			"FILL" 0,
			"wght" 300,
			"GRAD" 0,
			"opsz" 20;
		font-size: 20px;
	}
	.hover-lift {
		transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1);
