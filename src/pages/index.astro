	}

	@media (min-width: 768px) and (min-height: 550px) {
		body {
			overflow-y: hidden;
		}
		main {
			height: 100vh !important;
			max-height: 100vh !important;
			overflow: hidden !important;
			max-width: clamp(1000px, 85vw, 1200px) !important;
			display: flex;
			flex-direction: column;
			justify-content: center;
		}

		/* Base scaling for large screens / standard desktop */
		main > div {
			gap: clamp(1rem, 4vh, 3rem) !important;
		}

		h1 {
			font-size: clamp(3.5rem, 8vh, 6rem) !important;
			margin-bottom: clamp(0.25rem, 1.5vh, 1.5rem) !important;
		}

		#discordCard {
			margin-top: clamp(1rem, 4vh, 3rem) !important;
			padding: clamp(0.75rem, 2vh, 1.5rem) !important;
			margin-bottom: clamp(0.25rem, 1vh, 0.5rem) !important;
			/* max-width: clamp(20rem, 35vh, 24rem) !important; */
		}

		#discordCard .row {
			margin-top: clamp(0.5rem, 1.5vh, 1rem) !important;
			padding: clamp(0.375rem, 1vh, 0.75rem) !important;
		}

		#discordCard .dc-avatar {
			width: clamp(3rem, 7vh, 4rem) !important;
			height: clamp(3rem, 7vh, 4rem) !important;
		}

		/* Bottom section grid gap */
		main section.grid {
			gap: clamp(1.5rem, 6vw, 6rem) !important;
		}

		/* Spacing overrides for developer/projects lists */
		main section.grid .space-y-6 > :not([hidden]) ~ :not([hidden]) {
			margin-top: clamp(0.5rem, 2vh, 1.5rem) !important;
		}

		main section.grid div.mt-4 {
			margin-top: clamp(0.5rem, 2vh, 1rem) !important;
		}

		/* Project items */
		main section.grid a.group {
			padding-top: clamp(0.25rem, 0.8vh, 0.5rem) !important;
			padding-bottom: clamp(0.25rem, 0.8vh, 0.5rem) !important;
		}

		/* Minecraft button */
		main section.grid div.flex-col > a {
			padding-top: 0.5rem !important;
			padding-bottom: 0.5rem !important;
		}

		/* Scale down text content on shorter screens */
		@media (max-height: 850px) {
			main section.grid p {
				font-size: 15px !important;
				line-height: 1.5 !important;
			}
			main section.grid h2 {
				font-size: 10px !important;
			}
		}

		@media (max-height: 720px) {
			main section.grid p {
				font-size: 14px !important;
				line-height: 1.4 !important;
			}
		}
	}
</style>

<script>
	// Lanyard Integration
	const DISCORD_ID = "677724144762355714";
	const wsUrl = "wss://api.lanyard.rest/socket";

	const elements = {
		loading: document.getElementById("dcLoading"),
		status: document.getElementById("dcStatus"),
		avatar: document.getElementById("dcAvatar") as HTMLImageElement,
		display: document.getElementById("dcDisplay"),
		username: document.getElementById("dcUsername"),
		activity: document.getElementById("dcActivity"),
		actImg: document.getElementById("dcActImg") as HTMLImageElement,
		actName: document.getElementById("dcActName"),
		actDetail: document.getElementById("dcActDetail"),
		actState: document.getElementById("dcActState"),
		spotify: document.getElementById("dcSpotify"),
		spArt: document.getElementById("spArt") as HTMLImageElement,
		spSong: document.getElementById("spSong"),
		spArtist: document.getElementById("spArtist"),
		spCur: document.getElementById("spCur"),
		spTot: document.getElementById("spTot"),
		spFill: document.getElementById("spFill") as HTMLDivElement,
	};

	function formatTime(ms: number) {
		const seconds = Math.floor((ms / 1000) % 60);
		const minutes = Math.floor((ms / (1000 * 60)) % 60);
		return `${minutes}:${seconds.toString().padStart(2, "0")}`;
	}

	let spotifyInterval: number | undefined;

	function updateUI(data: any) {
		if (elements.loading) elements.loading.style.display = "none";

		const statusMap: Record<string, string> = {
			online: "online",
			idle: "idle",
			dnd: "dnd",
			offline: "offline",
		};
		if (elements.status)
			elements.status.className = `dc-status absolute bottom-0.5 right-0.5 w-4 h-4 rounded-full border-2 border-surface-container ${statusMap[data.discord_status] || "offline"}`;

		// if ((statusMap[data.discord_status] || "offline") === "offline") {
		// 	document.querySelector("#dcTop")?.classList.remove("mb-4"); // Sacar padding innecesario al no tener elementos en el estado
		// } else {
		// 	document.querySelector("#dcTop")?.classList.add("mb-4");
		// }

		if (elements.avatar)
			elements.avatar.src = `https://cdn.discordapp.com/avatars/${DISCORD_ID}/${data.discord_user.avatar}.webp?size=128`;
		if (elements.display)
			elements.display.textContent =
				data.discord_user.display_name || data.discord_user.username;
		if (elements.username)
			elements.username.textContent = `@${data.discord_user.username}`;

		const activities = data.activities || [];
		const gameAct = activities.find((a: any) => a.type === 0);

		if (gameAct && elements.activity) {
			elements.activity.classList.remove("hidden");
			if (elements.actName) elements.actName.textContent = gameAct.name;
			if (elements.actDetail)
				elements.actDetail.textContent = gameAct.details || "";
			if (elements.actState)
				elements.actState.textContent = gameAct.state || "";

			if (
				gameAct.assets &&
				gameAct.assets.large_image &&
				elements.actImg
			) {
				const assetId = gameAct.assets.large_image;
				const src = assetId.startsWith("mp:external")
					? `https://media.discordapp.net/external/${assetId.split("mp:external/")[1]}`
					: `https://cdn.discordapp.com/app-assets/${gameAct.application_id}/${assetId}.png`;
				elements.actImg.src = src;
				elements.actImg.classList.remove("hidden");
			} else if (elements.actImg) {
				elements.actImg.classList.add("hidden");
			}
		} else if (elements.activity) {
			elements.activity.classList.add("hidden");
		}

		if (data.listening_to_spotify && data.spotify && elements.spotify) {
			elements.spotify.classList.remove("hidden");
			elements.spotify.setAttribute(
				"data-spotify-start",
				data.spotify.timestamps.start,
			);
			elements.spotify.setAttribute(
				"data-spotify-end",
				data.spotify.timestamps.end,
			);

			if (elements.spArt) elements.spArt.src = data.spotify.album_art_url;
			if (elements.spSong)
				elements.spSong.textContent = data.spotify.song;
			if (elements.spArtist)
				elements.spArtist.textContent = data.spotify.artist;

			clearInterval(spotifyInterval);
			const updateSpotifyBar = () => {
				const now = Date.now();
				const total =
					data.spotify.timestamps.end - data.spotify.timestamps.start;
				const progress = Math.min(
					now - data.spotify.timestamps.start,
					total,
				);
				const percent = (progress / total) * 100;

				if (elements.spCur)
					elements.spCur.textContent = formatTime(progress);
				if (elements.spTot)
					elements.spTot.textContent = formatTime(total);
				if (elements.spFill)
					elements.spFill.style.width = `${percent}%`;
			};
			updateSpotifyBar();
			spotifyInterval = window.setInterval(updateSpotifyBar, 1000);
		} else if (elements.spotify) {
			elements.spotify.classList.add("hidden");
			clearInterval(spotifyInterval);
		}
	}

	function initInitialSpotifyState() {
		if (
			elements.spotify &&
			!elements.spotify.classList.contains("hidden")
		) {
			const start = parseInt(
				elements.spotify.getAttribute("data-spotify-start") || "0",
				10,
			);
			const end = parseInt(
				elements.spotify.getAttribute("data-spotify-end") || "0",
				10,
			);

			if (start > 0 && end > 0) {
				clearInterval(spotifyInterval);
				const updateSpotifyBar = () => {
					const now = Date.now();
					const total = end - start;
					const progress = Math.min(now - start, total);
					const percent = (progress / total) * 100;

					if (elements.spCur)
						elements.spCur.textContent = formatTime(progress);
					if (elements.spTot)
						elements.spTot.textContent = formatTime(total);
					if (elements.spFill)
						elements.spFill.style.width = `${percent}%`;
				};
				updateSpotifyBar();
				spotifyInterval = window.setInterval(updateSpotifyBar, 1000);
			}
		}
	}

	function connectWS() {
		const socket = new WebSocket(wsUrl);
		socket.onopen = () => {
			socket.send(
				JSON.stringify({
					op: 2,
					d: { subscribe_to_id: DISCORD_ID },
				}),
			);
		};
		socket.onmessage = (event) => {
			const msg = JSON.parse(event.data);
			if (msg.t === "INIT_STATE" || msg.t === "PRESENCE_UPDATE") {
				updateUI(msg.d);
			}
		};
		socket.onclose = () => setTimeout(connectWS, 5000);
	}

	// Start initial spotify interval if rendered by SSR
	initInitialSpotifyState();

	// Connect websocket for live updates
	connectWS();
</script>
