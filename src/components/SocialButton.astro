---
export interface Props {
    href: string;
    ariaLabel: string;
}

const { href, ariaLabel } = Astro.props;
---

<a
    href={href}
    target="_blank"
    rel="noopener"
    aria-label={ariaLabel}
    data-cuelume-hover="tick"
    data-cuelume-press
    data-cuelume-release
    class="inline-flex items-center justify-center w-13 h-13 rounded-full border border-border-subtle bg-white/3 text-primary backdrop-blur-md transition-all duration-150 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-0.75 hover:bg-white/8 hover:border-secondary [&_svg]:w-6 [&_svg]:h-6 [&_svg]:fill-current"
>
    <slot />
</a>
